  "articles": {
    "kuznetsov2017_chua_integer_df": {
      "bibliography": {
        "authors": "N. V. Kuznetsov, O. A. Kuznetsova, G. A. Leonov, T. N. Mokaev, N. V. Stankevich",
        "year": 2017,
        "title": "Localization of hidden Chua attractors by the describing function method",
        "venue": "IFAC-PapersOnLine",
        "doi": "10.1016/j.ifacol.2017.08.1633"
      },
      "system": {
        "id": "chua_integer_saturation",
        "order": 1.0,
        "equations": [
          "dx/dt = alpha*(y - x*(m1+1)) - alpha*psi(x)",
          "dy/dt = x - y + z",
          "dz/dt = -(beta*y + gamma*z)",
          "psi(x) = (m0-m1)*sat(x) = 0.5*(m0-m1)*(abs(x+1)-abs(x-1))"
        ],
        "lure": {
          "P": "[[-alpha*(m1+1), alpha, 0], [1,-1,1], [0,-beta,-gamma]]",
          "q_vector": "[-alpha,0,0]^T",
          "r_vector": "[1,0,0]^T",
          "transfer": "W(p)=r^T(P-pI)^(-1)q",
          "condition": "Im W(i*omega0)=0; k=-(Re W(i*omega0))^(-1)"
        }
      },
      "published_cases": [
        {
          "case_id": "kuznetsov2017_case_18_hidden_chaotic",
          "parameters": {
            "alpha": 8.4562,
            "beta": 12.0732,
            "gamma": 0.0052,
            "m0": -0.1768,
            "m1": -1.1468
          },
          "equilibria": {
            "F0": [
              0.0,
              0.0,
              0.0
            ],
            "S_plus_approx": [
              6.5883,
              0.0029,
              -6.5855
            ],
            "S_minus_approx": [
              -6.5883,
              -0.0029,
              6.5855
            ],
            "classification": "F0 stable focus-node; S± saddle-foci with one-dimensional unstable manifolds"
          },
          "df_data": {
            "omega0": 2.0392,
            "k": 0.2098,
            "a0": 5.8576
          },
          "seed_plus": [
            5.8576,
            0.3694,
            -8.3686
          ],
          "seed_minus": [
            -5.8576,
            -0.3694,
            8.3686
          ],
          "reported_status": "two symmetric hidden chaotic attractors localized by direct use of DF initial data; authors state they skip multistep small-parameter continuation for this case.",
          "usable_for_phases": [
