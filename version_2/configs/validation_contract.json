{
  "contract_name": "caputo_hidden_attractors_official_methodology",
  "version": 2,
  "protocol_version": "caputo_hidden_attractors_v1",
  "schema_version": "1.0",
  "purpose": "Official evidence contract from numerical settings through tested hiddenness conclusions.",
  "output_root": "validation",
  "manifest": {
    "directory": "00_manifest",
    "required_files": [
      "validation_manifest.json",
      "environment.json",
      "software_versions.json"
    ],
    "required_fields": [
      "validation_id",
      "repository_commit",
      "package_version",
      "python_version",
      "platform",
      "main_system",
      "main_parameters",
      "stages"
    ]
  },
  "stage_pattern": {
    "human_report": "<stage>_validation.md",
    "summary": "<stage>_validation_summary.json",
    "tables": "*.csv",
    "figures": ["*.png", "*.pdf"]
  },
  "stages": [
    {
      "id": "01_numerical_contract",
      "slug": "numerical_contract",
      "summary": "numerical_contract_validation_summary.json",
      "expected_evidence": ["numerical_contract_validation.md", "effective_contract.json", "integrator_benchmark_summary.csv"]
    },
    {
      "id": "02_algebraic_validation",
      "slug": "algebraic_validation",
      "summary": "algebraic_validation_validation_summary.json",
      "expected_evidence": ["algebraic_validation_validation.md", "equilibria_summary.csv", "jacobian_check.csv", "eigenvalues_matignon_summary.csv", "transfer_function_check.csv"]
    },
    {
      "id": "03_seed_generation",
      "slug": "seed_generation",
      "summary": "seed_generation_validation_summary.json",
      "expected_evidence": ["seed_generation_validation.md", "unified_seeds.json", "harmonic_residuals.csv"]
    },
    {
      "id": "04_soft_precheck",
      "slug": "soft_precheck",
      "summary": "soft_precheck_validation_summary.json",
      "expected_evidence": ["soft_precheck_validation.md", "precheck_decisions.csv"]
    },
    {
      "id": "05_continuation",
      "slug": "continuation",
      "summary": "continuation_validation_summary.json",
      "expected_evidence": ["continuation_validation.md", "continuation_plan.json", "continuation_trace.csv"]
    },
    {
      "id": "06_post_continuation_filter",
      "slug": "post_continuation_filter",
      "summary": "post_continuation_filter_validation_summary.json",
      "expected_evidence": ["post_continuation_filter_validation.md", "survivor_decisions.csv"]
    },
    {
      "id": "07_dynamic_reference",
      "slug": "dynamic_reference",
      "summary": "dynamic_reference_validation_summary.json",
      "expected_evidence": ["dynamic_reference_validation.md", "dynamic_reference.json", "trajectory_metrics.csv", "similarity_signature.json"]
    },
    {
      "id": "08_robustness",
      "slug": "robustness",
      "summary": "robustness_validation_summary.json",
      "expected_evidence": ["robustness_validation.md", "robustness_metrics.csv", "robustness_verdicts.json", "abm_efork_comparison.csv"]
    },
    {
      "id": "09_hiddenness_tests",
      "slug": "hiddenness_tests",
      "summary": "hiddenness_tests_validation_summary.json",
      "expected_evidence": ["hiddenness_tests_validation.md", "ball_sampling_plan.csv", "ball_sampling_results.csv", "basin_slices_summary.json"]
    },
    {
      "id": "10_diagnostics",
      "slug": "diagnostics",
      "summary": "diagnostics_validation_summary.json",
      "expected_evidence": ["diagnostics_validation.md", "fft_summary.csv", "psd_summary.csv", "lyapunov_summary.csv"]
    }
  ],
  "summary_required_fields": [
    "schema_version",
    "protocol_version",
    "stage",
    "status",
    "system",
    "numerical_contract",
    "inputs",
    "outputs",
    "metrics",
    "verdict",
    "files",
    "provenance"
  ],
  "final_report": {
    "source": "validation/final_validation_report.tex",
    "compiled": "validation/final_validation_report.pdf"
  }
}
