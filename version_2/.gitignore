# Ignore all dynamically generated output files under validation/outputs
validation/outputs/**/*

# But keep the committed/required reference case data
!validation/outputs/**/.gitkeep
!validation/outputs/**/.gitignore
!validation/outputs/integrator_method_validation/*.csv
!validation/outputs/integrator_method_validation/*.json
!validation/outputs/lyapunov_benchmarks/**/*.csv
!validation/outputs/lyapunov_benchmarks/**/*.json
!validation/outputs/published_cases/**/*.json
!validation/outputs/published_continuation_comparison/**/*.csv
!validation/outputs/published_continuation_comparison/**/*.json

# pytest-benchmark baselines (platform-specific; store explicitly when needed)
.benchmarks/

# Decide if outputs_unified/ should be versioned or not.
outputs_unified/

# Generated project figures
library_figures/

# Clean repository strategy: Ignore all dynamic/generated graphic outputs
*.png
*.pdf
*.svg
*.jpg
*.jpeg

# Unignore documentation assets
!docs/assets/**/*.png
!docs/assets/**/*.pdf
!docs/assets/**/*.svg
!docs/assets/**/*.jpg
!docs/assets/**/*.jpeg

# Unignore committed validation reference cases (ground-truth plots)
!validation/reference_cases/**/*.png
!validation/reference_cases/**/*.pdf
!validation/reference_cases/**/*.jpg
!validation/reference_cases/**/*.jpeg

# Historical local archive; not part of active library, tests, docs or package distribution
_archived_figure_scripts/

